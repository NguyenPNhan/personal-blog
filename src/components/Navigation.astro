---
import { siteConfig } from '../config/site'

const path = Astro.url.pathname
const isActive = (href: string) => href === '/' ? path === '/' : path.startsWith(href)
---

<header class="site-header">
  <nav class="site-nav" aria-label="Main navigation">
    <a class="site-brand" href="/" aria-label={`${siteConfig.name} home`}>
      <span class="brand-mark" aria-hidden="true">NP</span>
      <span>{siteConfig.name}</span>
    </a>

    <ul class="nav-links nav-links-desktop">
      {siteConfig.navigation.map((item) => (
        <li>
          <a href={item.href} class:list={{ active: isActive(item.href) }} aria-current={isActive(item.href) ? 'page' : undefined}>
            {item.label}
          </a>
        </li>
      ))}
    </ul>

    <details class="mobile-nav">
      <summary>Menu <span aria-hidden="true">＋</span></summary>
      <ul class="nav-links">
        {siteConfig.navigation.map((item) => (
          <li>
            <a href={item.href} class:list={{ active: isActive(item.href) }} aria-current={isActive(item.href) ? 'page' : undefined}>
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </details>
  </nav>
</header>
