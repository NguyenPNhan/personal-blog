---
import BaseLayout from '../layouts/BaseLayout.astro'
import githubIcon from '../assets/icons/github.png'
import { siteConfig } from '../config/site'
---

<BaseLayout>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="hero-eyebrow">{siteConfig.hero.eyebrow}</p>
        <h1 class="hero-title"><span class="hero-name">{siteConfig.hero.name}</span></h1>
        <p class="hero-intro">{siteConfig.hero.intro}</p>
        <div class="hero-actions">
          <a class="button-primary" href="/blog">Read the blog <span aria-hidden="true">→</span></a>
          <a class="button-secondary" href="/project">Explore projects</a>
          <a class="button-secondary" href="/research">Explore research</a>
        </div>
      </div>

      <div class="hero-art">
        <a class="hero-social" href={siteConfig.github} target="_blank" rel="noreferrer" aria-label="NguyenPNhan on GitHub">
          <img class="github-icon" src={githubIcon.src} alt="" width="512" height="512" />
        </a>
        <div class="portrait-frame">
          <img src="/og.png" alt="Cartoon developer writing beside a cat" />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
